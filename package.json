    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lenis": "^1.3.18-dev.0",
    "motion": "^12.34.4",
    "next": "^16.1.6",
    "next-view-transitions": "^0.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.9",
    "@biomejs/biome": "2.4.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
